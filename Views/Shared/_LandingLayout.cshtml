<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZoneBill</title>
    <meta name="description" content="ZoneBill — The all-in-one venue management platform for billiard halls, KTVs, board game cafés, escape rooms, and gaming shops. POS, bookings, inventory, and accounting in one system." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            corePlugins: { preflight: false },
            important: false,
            blocklist: ['collapse'],
            theme: {
                extend: {
                    colors: {
                        cyan: { 400: '#22d3ee', 500: '#06b6d4' },
                        orange: { 500: '#f97316' }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ZoneBill_Lloren.styles.css" asp-append-version="true" />
    <style>
        /* Inter font for landing page */
        .lp-body, .lp-body * {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* Cursor glow */
        #lp-cursor-glow {
            position: fixed;
            top: 0; left: 0;
            width: 450px; height: 450px;
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            background: radial-gradient(circle, rgba(6,182,212,0.10) 0%, rgba(6,182,212,0.04) 35%, transparent 70%);
            transform: translate(-50%, -50%);
            transition: opacity 0.4s ease;
            opacity: 0;
            will-change: transform;
        }
    </style>
</head>
<body class="lp-body">
    <div id="lp-cursor-glow"></div>

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            var glow = document.getElementById('lp-cursor-glow');
            if (!glow) return;
            var raf; var mx = 0; var my = 0;

            document.addEventListener('mousemove', function (e) {
                mx = e.clientX; my = e.clientY;
                glow.style.opacity = '1';
                cancelAnimationFrame(raf);
                raf = requestAnimationFrame(function () {
                    glow.style.left = mx + 'px';
                    glow.style.top  = my + 'px';
                });
            }, { passive: true });

            document.addEventListener('mouseleave', function () {
                glow.style.opacity = '0';
            });
        })();
    </script>
</body>
</html>
