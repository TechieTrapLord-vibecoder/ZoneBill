@model ZoneBill_Lloren.Models.Payment
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Payment Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-info-circle me-2" style="color:var(--zb-secondary);"></i>Payment Details</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.PaymentId" class="btn btn-sm fw-semibold" style="background:rgba(249,115,22,0.12);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Business)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Business.BusinessName)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Invoice)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Invoice.PaymentStatus)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.AmountPaid)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.AmountPaid)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.PaymentMethod)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.PaymentMethod)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.PaymentDate)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@PhilippineTime.ToDateTime(Model.PaymentDate).ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.ReferenceNumber)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.ReferenceNumber)</dd>
        </dl>
    </div>
</div>
