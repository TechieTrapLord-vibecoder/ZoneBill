@{
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-key me-2" style="color:var(--zb-secondary);"></i>Reset Password</h4>
        <p class="text-muted small mb-0">Set a new password for <strong style="color:var(--zb-text);">@ViewBag.UserName</strong>.</p>
    </div>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mb-3">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<div class="zb-table-card" style="max-width:480px;">
    <div class="p-4">
        <form asp-action="ResetPassword" asp-route-id="@ViewBag.UserId" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="zb-form-label mb-1">New Password</label>
                <input type="password" name="newPassword" class="form-control zb-input" placeholder="Min. 6 characters" autocomplete="new-password">
            </div>
            <button type="submit" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
                <i class="bi bi-check-lg me-1"></i> Reset Password
            </button>
        </form>
    </div>
</div>
