@model IEnumerable<ZoneBill_Lloren.Models.Business>
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Businesses";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-building me-2" style="color:var(--zb-secondary);"></i>Businesses</h4>
        <p class="text-muted small mb-0">All registered tenant businesses on ZoneBill.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> Add Business
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Businesses</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.Count()</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(34,197,94,0.4);">
            <div class="zb-kpi-label">Active</div>
            <div class="zb-kpi-value" style="color:#22c55e;">@Model.Count(b => b.IsActive)</div>
        </div>
    </div>
</div>

<div class="zb-table-card">
    <div class="table-responsive">
        <table class="table zb-table mb-0">
            <thead>
                <tr>
                    <th>Business Name</th>
                    <th>Plan</th>
                    <th>Domain Prefix</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody data-paginate="5">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold" style="color:var(--zb-text);">@item.BusinessName</td>
                        <td>@(item.Plan?.PlanName ?? "—")</td>
                        <td><span class="zb-mono">@item.DomainPrefix</span></td>
                        <td><span class="zb-mono">@PhilippineTime.ToDateTime(item.CreatedAt).ToString("MMM d, yyyy")</span></td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="zb-badge zb-badge-green">Active</span>
                            }
                            else
                            {
                                <span class="zb-badge zb-badge-red">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.BusinessId" class="zb-action-btn" title="View"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.BusinessId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.BusinessId" class="zb-action-btn zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
