@model ZoneBill_Lloren.Models.Business

@{
    ViewData["Title"] = "Business Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);">
        <i class="bi bi-info-circle me-2" style="color:var(--zb-secondary);"></i>Business Details
    </h4>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.BusinessId" class="btn btn-sm fw-semibold me-2" style="background:rgba(249,115,22,0.15);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);">
            <i class="bi bi-pencil-square me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Plan)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Plan.PlanName)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.BusinessName)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.BusinessName)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.DomainPrefix)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.DomainPrefix)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.LogoUrl)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">
                @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                {
                    <a href="@Model.LogoUrl" target="_blank" rel="noopener noreferrer" style="color:var(--zb-secondary);">@Model.LogoUrl</a>
                }
                else
                {
                    <span style="color:var(--zb-text-muted);">-</span>
                }
            </dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.TaxRatePercentage)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Model.TaxRatePercentage.ToString("0.##")%</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.CreatedAt)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.IsActive)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.IsActive)</dd>
        </dl>
    </div>
</div>
