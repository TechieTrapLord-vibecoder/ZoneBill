@model IEnumerable<ZoneBill_Lloren.Models.JournalEntryTimelineViewModel>
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Journal Entries";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-book me-2" style="color:var(--zb-secondary);"></i>Journal Entries</h4>
        <p class="text-muted small mb-0">Double-entry ledger records grouped by transaction.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> New Entry
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Entries</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.Count()</div>
        </div>
    </div>
</div>

<div class="zb-table-card">
    <div class="table-responsive">
        <table class="table zb-table mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Ref#</th>
                    <th>Description</th>
                    <th class="text-end">Debit</th>
                    <th class="text-end">Credit</th>
                    <th></th>
                </tr>
            </thead>
            <tbody data-paginate="5">
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="zb-mono" style="font-size:.82rem;">@PhilippineTime.ToDateTime(item.Entry.EntryDate).ToString("MMM d, yyyy")</span></td>
                        <td><span style="color:var(--zb-secondary);font-size:.82rem;">@item.Entry.ReferenceType #@item.Entry.ReferenceId</span></td>
                        <td style="max-width:260px;" class="text-truncate">@item.Entry.Description</td>
                        <td class="text-end zb-mono" style="color:#22c55e;font-size:.85rem;">@item.TotalDebit.ToString("C")</td>
                        <td class="text-end zb-mono" style="color:var(--zb-accent);font-size:.85rem;">@item.TotalCredit.ToString("C")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn" title="View"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>