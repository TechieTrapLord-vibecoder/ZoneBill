@model IEnumerable<ZoneBill_Lloren.Models.JournalEntryTimelineViewModel>
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Ledger Timeline";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-book me-2" style="color:var(--zb-secondary);"></i>Ledger Timeline</h4>
        <p class="text-muted small mb-0">Most recent entries first — debits and credits grouped by transaction.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> New Entry
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Entries</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.Count()</div>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="zb-table-card mb-3">
        <div class="px-4 py-3 d-flex justify-content-between align-items-start border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
            <div>
                <span class="zb-mono" style="color:var(--zb-secondary); font-size:.85rem;">@PhilippineTime.ToDateTime(item.Entry.EntryDate).ToString("MMM d, yyyy h:mm tt")</span>
                <div class="fw-semibold mt-1" style="color:var(--zb-text);">@item.Entry.ReferenceType <span style="color:var(--zb-text-muted);">#@item.Entry.ReferenceId</span></div>
                <div class="small" style="color:var(--zb-text-muted);">@item.Entry.Description</div>
            </div>
            <div class="text-end small flex-shrink-0 ms-3">
                <div>Debit: <strong style="color:#22c55e;">@item.TotalDebit.ToString("C")</strong></div>
                <div>Credit: <strong style="color:var(--zb-accent);">@item.TotalCredit.ToString("C")</strong></div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table zb-table mb-0">
                <thead>
                    <tr>
                        <th>Account</th>
                        <th class="text-end">Debit</th>
                        <th class="text-end">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in item.Lines)
                    {
                        <tr>
                            <td>@line.ChartOfAccount.AccountName</td>
                            <td class="text-end zb-mono" style="color:#22c55e;">@(line.Debit > 0 ? line.Debit.ToString("C") : "—")</td>
                            <td class="text-end zb-mono" style="color:var(--zb-accent);">@(line.Credit > 0 ? line.Credit.ToString("C") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2 border-top d-flex gap-2" style="border-color:rgba(6,182,212,0.15)!important;">
            <a asp-action="Details" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn" title="View"><i class="bi bi-eye"></i></a>
            <a asp-action="Edit" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil"></i></a>
            <a asp-action="Delete" asp-route-id="@item.Entry.JournalEntryId" class="zb-action-btn zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
        </div>
    </div>
}
