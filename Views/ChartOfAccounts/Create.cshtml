@model ZoneBill_Lloren.Models.ChartOfAccount

@{
    ViewData["Title"] = "Create Account";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-plus-circle me-2" style="color:var(--zb-secondary);"></i>Create Account</h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="BusinessId" class="form-label zb-form-label"></label>
                    <select asp-for="BusinessId" class="form-select zb-form-input" asp-items="ViewBag.BusinessId"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountName" class="form-label zb-form-label"></label>
                    <input asp-for="AccountName" class="form-control zb-form-input" />
                    <span asp-validation-for="AccountName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountType" class="form-label zb-form-label"></label>
                    <input asp-for="AccountType" class="form-control zb-form-input" />
                    <span asp-validation-for="AccountType" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input class="form-check-input" asp-for="IsActive" style="background-color:var(--zb-primary-mid);border-color:var(--zb-text-muted);" />
                        <label class="form-check-label zb-form-label" asp-for="IsActive">@Html.DisplayNameFor(model => model.IsActive)</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;"><i class="bi bi-check-lg me-1"></i>Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
