@model ZoneBill_Lloren.Models.CustomerPortalViewModel
@using ZoneBill_Lloren.Helpers

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.SpaceName — @Model.BusinessName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --bg-primary: #0F172A;
            --bg-card: #1E293B;
            --bg-card-alt: #334155;
            --accent-cyan: #06B6D4;
            --accent-orange: #F97316;
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
        }
        body {
            background: var(--bg-primary);
            color: var(--text-main);
            min-height: 100vh;
        }
        .card {
            background: var(--bg-card);
            border: 1px solid var(--bg-card-alt);
        }
        .card-header {
            background: var(--bg-card-alt) !important;
            border-bottom: 1px solid var(--accent-cyan);
            color: var(--accent-cyan);
            font-weight: 600;
        }
        .text-muted { color: var(--text-muted) !important; }
        .btn-order {
            background: var(--accent-orange);
            color: #fff;
            border: none;
            font-weight: 600;
        }
        .btn-order:hover { background: #ea6c10; color: #fff; }
        .badge-stock { background: var(--accent-cyan); color: var(--bg-primary); font-weight: 600; }
        .timer-display {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--accent-cyan);
            font-family: 'Consolas', 'Courier New', monospace;
        }
        .bill-row { display: flex; justify-content: space-between; padding: 0.25rem 0; color: var(--text-main); }
        .bill-total { border-top: 2px solid var(--accent-cyan); font-size: 1.2rem; font-weight: 700; padding-top: 0.5rem; margin-top: 0.5rem; color: var(--text-main); }
        .menu-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
        .menu-item-card {
            background: var(--bg-card-alt);
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .order-table th { color: var(--accent-cyan); border-color: var(--bg-card-alt); }
        .order-table td { border-color: var(--bg-card-alt); }
        .form-control, .form-select {
            background: var(--bg-card-alt);
            color: var(--text-main);
            border-color: var(--bg-card-alt);
        }
        .form-control:focus, .form-select:focus {
            background: var(--bg-card-alt);
            color: var(--text-main);
            border-color: var(--accent-cyan);
            box-shadow: 0 0 0 0.2rem rgba(6, 182, 212, 0.25);
        }
    </style>
</head>
<body>

<div class="container py-3" style="max-width: 540px;">

    <!-- Header -->
    <div class="text-center mb-3">
        <div class="text-muted small">@Model.BusinessName</div>
        <h3 class="mb-0" style="color: var(--accent-cyan);">@Model.SpaceName</h3>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2">@TempData["Success"]</div>
    }

    @if (!Model.HasActiveSession)
    {
        <div class="card text-center p-4 mt-4">
            <div style="font-size: 3rem;">🎱</div>
            <h5 class="mt-2">This table is not in use</h5>
            <p class="text-muted mb-0">Please ask the front desk to start a session.</p>
        </div>
    }
    else
    {
        <!-- Session Info -->
        <div class="card mb-3">
            <div class="card-header">Session</div>
            <div class="card-body text-center">
                <div class="timer-display" id="elapsedTimer"
                     data-start-time="@Model.StartTime?.ToString("o")"
                     data-hourly-rate="@Model.HourlyRate">
                    00:00:00
                </div>
                <div class="text-muted small mt-1">
                    ₱@Model.HourlyRate.ToString("0.00") / hr &bull; Ref: @Model.ReferenceCode
                </div>
            </div>
        </div>

        <!-- Current Orders -->
        @if (Model.OrderItems.Any())
        {
            <div class="card mb-3">
                <div class="card-header">Your Orders</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-dark order-table mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.ItemName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">₱@item.LineTotal.ToString("0.00")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Running Bill -->
        <div class="card mb-3">
            <div class="card-header">Estimated Bill</div>
            <div class="card-body">
                <div class="bill-row">
                    <span>Table time</span>
                    <span id="billTimeCharge">₱@Model.TimeCharge.ToString("0.00")</span>
                </div>
                <div class="bill-row">
                    <span>Food & drinks</span>
                    <span>₱@Model.MenuTotal.ToString("0.00")</span>
                </div>
                <div class="bill-row text-muted small">
                    <span>Tax (@Model.TaxRatePercent.ToString("0.##")%)</span>
                    <span id="billTax">₱@Model.TaxAmount.ToString("0.00")</span>
                </div>
                <div class="bill-row bill-total" style="color: var(--accent-orange);">
                    <span>Estimated Total</span>
                    <span id="billTotal">₱@Model.EstimatedTotal.ToString("0.00")</span>
                </div>
                <div class="text-muted small text-center mt-2">Final bill will be at the front desk</div>
            </div>
        </div>

        <!-- Request Checkout -->
        <div class="card mb-3">
            <div class="card-body text-center">
                @if (Model.CheckoutRequested)
                {
                    <div class="py-2">
                        <i class="bi bi-check-circle-fill" style="font-size:2rem;color:#22c55e;"></i>
                        <p class="mt-2 mb-0 fw-semibold" style="color:#22c55e;">Checkout requested — front desk has been notified.</p>
                    </div>
                }
                else
                {
                    <form method="post" action="/Customer/Space/@Model.SpaceId/RequestCheckout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-order w-100 py-2" style="background:#ef4444;">
                            <i class="bi bi-box-arrow-right me-1"></i> Request Checkout
                        </button>
                    </form>
                    <div class="text-muted small mt-2">Notify front desk you're ready to pay</div>
                }
            </div>
        </div>

        <!-- Menu & Order Form -->
        <div class="card mb-3">
            <div class="card-header">Order Food & Drinks</div>
            <div class="card-body">
                @if (Model.MenuItems.Any())
                {
                    <form method="post" action="/Customer/Space/@Model.SpaceId/Order">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SpaceId" value="@Model.SpaceId" />

                        <div class="mb-3">
                            <select class="form-select" name="ItemId" id="menuSelect" required>
                                <option value="">Select an item...</option>
                                @foreach (var item in Model.MenuItems)
                                {
                                    <option value="@item.ItemId" data-price="@item.Price" data-stock="@item.StockAvailable">
                                        @item.ItemName — ₱@item.Price.ToString("0.00")
                                    </option>
                                }
                            </select>
                        </div>

                        <div id="selectedItemInfo" class="mb-3" style="display:none;">
                            <div class="menu-item-card">
                                <div>
                                    <strong id="selItemName"></strong>
                                    <div class="text-muted small">₱<span id="selItemPrice"></span> each</div>
                                </div>
                                <span class="badge badge-stock" id="selItemStock"></span>
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-5">
                                <label class="form-label small text-muted">Quantity</label>
                                <input class="form-control" type="number" name="Quantity" id="qtyInput" value="1" min="1" max="99" required />
                            </div>
                            <div class="col-7 d-flex align-items-end">
                                <button type="submit" class="btn btn-order w-100 py-2">Add to Order</button>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <p class="text-muted text-center mb-0">No items available right now.</p>
                }
            </div>
        </div>
    }

    <div class="text-center text-muted small pb-3">
        Powered by <strong style="color: var(--accent-cyan);">ZoneBill</strong>
    </div>
</div>

<script>
    // ── Live elapsed timer & dynamic bill update ──
    (function () {
        var timerEl = document.getElementById('elapsedTimer');
        if (!timerEl) return;

        var startStr = timerEl.getAttribute('data-start-time');
        if (!startStr) return;

        var startMs = new Date(startStr).getTime();
        var hourlyRate = parseFloat(timerEl.getAttribute('data-hourly-rate')) || 0;
        var menuTotal = @(Model.HasActiveSession ? Model.MenuTotal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : "0");
        var taxPct = @(Model.HasActiveSession ? (Model.TaxRatePercent / 100m).ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture) : "0");

        function pad(n) { return n < 10 ? '0' + n : '' + n; }

        function tick() {
            var now = Date.now();
            var diff = Math.max(0, Math.floor((now - startMs) / 1000));
            var h = Math.floor(diff / 3600);
            var m = Math.floor((diff % 3600) / 60);
            var s = diff % 60;
            timerEl.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);

            var hours = diff / 3600;
            if (hours < 0.01) hours = 0.01;

            var timeCharge = Math.round(hours * hourlyRate * 100) / 100;
            var sub = timeCharge + menuTotal;
            var tax = Math.round(sub * taxPct * 100) / 100;
            var total = Math.round((sub + tax) * 100) / 100;

            var tcEl = document.getElementById('billTimeCharge');
            var txEl = document.getElementById('billTax');
            var ttEl = document.getElementById('billTotal');
            if (tcEl) tcEl.textContent = '₱' + timeCharge.toFixed(2);
            if (txEl) txEl.textContent = '₱' + tax.toFixed(2);
            if (ttEl) ttEl.textContent = '₱' + total.toFixed(2);
        }

        tick();
        setInterval(tick, 1000);
    })();

    // ── Menu item selection info ──
    (function () {
        var sel = document.getElementById('menuSelect');
        var info = document.getElementById('selectedItemInfo');
        if (!sel || !info) return;

        sel.addEventListener('change', function () {
            var opt = sel.options[sel.selectedIndex];
            if (!opt.value) { info.style.display = 'none'; return; }
            document.getElementById('selItemName').textContent = opt.textContent.split('—')[0].trim();
            document.getElementById('selItemPrice').textContent = parseFloat(opt.getAttribute('data-price')).toFixed(2);
            document.getElementById('selItemStock').textContent = opt.getAttribute('data-stock') + ' in stock';
            info.style.display = 'block';
        });
    })();
</script>

</body>
</html>
