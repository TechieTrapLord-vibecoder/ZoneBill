@model IEnumerable<ZoneBill_Lloren.Models.Order>
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-bag-check me-2" style="color:var(--zb-secondary);"></i>Orders</h4>
        <p class="text-muted small mb-0">All food and beverage orders placed during sessions.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> New Order
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Orders</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.Count()</div>
        </div>
    </div>
</div>

<div class="zb-table-card">
    <div class="table-responsive">
        <table class="table zb-table mb-0">
            <thead>
                <tr>
                    <th>Business</th>
                    <th>Booking Status</th>
                    <th>Cashier</th>
                    <th>Order Time</th>
                    <th></th>
                </tr>
            </thead>
            <tbody data-paginate="5">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold" style="color:var(--zb-text);">@item.Business?.BusinessName</td>
                        <td>@item.Booking?.BookingStatus</td>
                        <td>@item.Cashier?.EmailAddress</td>
                        <td><span class="zb-mono">@PhilippineTime.ToDateTime(item.OrderTime).ToString("MMM d, h:mm tt")</span></td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.OrderId" class="zb-action-btn" title="View"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.OrderId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.OrderId" class="zb-action-btn zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
