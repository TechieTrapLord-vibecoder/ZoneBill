@model ZoneBill_Lloren.Models.InvoiceItem

@{
    ViewData["Title"] = "Edit Invoice Item";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);">
        <i class="bi bi-pencil-square me-2" style="color:var(--zb-secondary);"></i>Edit Invoice Item
    </h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="InvoiceItemId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="InvoiceId" class="form-label zb-form-label"></label>
                    <select asp-for="InvoiceId" class="form-select zb-form-input" asp-items="ViewBag.InvoiceId"></select>
                    <span asp-validation-for="InvoiceId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ItemType" class="form-label zb-form-label"></label>
                    <input asp-for="ItemType" class="form-control zb-form-input" />
                    <span asp-validation-for="ItemType" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Description" class="form-label zb-form-label"></label>
                    <input asp-for="Description" class="form-control zb-form-input" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Quantity" class="form-label zb-form-label"></label>
                    <input asp-for="Quantity" class="form-control zb-form-input" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="UnitPrice" class="form-label zb-form-label"></label>
                    <input asp-for="UnitPrice" class="form-control zb-form-input" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Total" class="form-label zb-form-label"></label>
                    <input asp-for="Total" class="form-control zb-form-input" />
                    <span asp-validation-for="Total" class="text-danger"></span>
                </div>
                <div class="col-12 mt-4">
                    <button type="submit" class="btn fw-semibold px-4" style="background:var(--zb-secondary);color:#0f172a;border:none;">
                        <i class="bi bi-check-lg me-1"></i>Save
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
