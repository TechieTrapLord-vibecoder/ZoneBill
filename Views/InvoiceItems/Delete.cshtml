@model ZoneBill_Lloren.Models.InvoiceItem

@{
    ViewData["Title"] = "Delete Invoice Item";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);">
        <i class="bi bi-trash me-2" style="color:#ef4444;"></i>Delete Invoice Item
    </h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="zb-table-card" style="border:1px solid rgba(239,68,68,0.3);">
    <div class="p-3" style="background:rgba(239,68,68,0.06);border-bottom:1px solid rgba(239,68,68,0.15);">
        <span style="color:#fca5a5;"><i class="bi bi-exclamation-triangle me-2"></i>Are you sure you want to delete this invoice item? This action cannot be undone.</span>
    </div>
    <div class="p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Invoice)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Invoice.PaymentStatus)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.ItemType)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.ItemType)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Description)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Description)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Quantity)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Quantity)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.UnitPrice)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.UnitPrice)</dd>
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Total)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Total)</dd>
        </dl>
        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="InvoiceItemId" />
            <button type="submit" class="btn fw-semibold px-4" style="background:rgba(239,68,68,0.2);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
            <a asp-action="Index" class="btn btn-sm fw-semibold ms-2" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">Cancel</a>
        </form>
    </div>
</div>
