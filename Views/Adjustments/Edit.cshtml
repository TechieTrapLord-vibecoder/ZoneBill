@model ZoneBill_Lloren.Models.Adjustment

@{
    ViewData["Title"] = "Edit Adjustment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-pencil-square me-2" style="color:var(--zb-secondary);"></i>Edit Adjustment</h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="AdjustmentId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="InvoiceId" class="form-label zb-form-label"></label>
                    <select asp-for="InvoiceId" class="form-select zb-form-input" asp-items="ViewBag.InvoiceId"></select>
                    <span asp-validation-for="InvoiceId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AdjustmentType" class="form-label zb-form-label"></label>
                    <select asp-for="AdjustmentType" class="form-select zb-form-input">
                        <option value="">Select type…</option>
                        <option value="Debit">Debit (Increases balance)</option>
                        <option value="Credit">Credit (Decreases balance)</option>
                    </select>
                    <span asp-validation-for="AdjustmentType" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Amount" class="form-label zb-form-label"></label>
                    <input asp-for="Amount" class="form-control zb-form-input" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Reason" class="form-label zb-form-label"></label>
                    <input asp-for="Reason" class="form-control zb-form-input" />
                    <span asp-validation-for="Reason" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;"><i class="bi bi-check-lg me-1"></i>Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
