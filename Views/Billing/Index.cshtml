@model ZoneBill_Lloren.Models.BillingPageViewModel
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Billing & Plan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);">
        <i class="bi bi-credit-card me-2" style="color:var(--zb-secondary);"></i>Billing & Plan
    </h4>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert" style="background:rgba(239,68,68,0.15);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert" style="background:rgba(16,185,129,0.15);color:#6ee7b7;border:1px solid rgba(16,185,129,0.3);">@TempData["Success"]</div>
}

@if (Model.IsSubscriptionExpired)
{
    <div class="alert" style="background:rgba(249,115,22,0.15);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);">
        <i class="bi bi-exclamation-triangle me-2"></i>Your subscription is not active. Renew now to restore POS access.
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="zb-table-card h-100">
            <div class="p-3">
                <div class="zb-kpi-label">Current Plan</div>
                <div class="zb-kpi-value" style="color:var(--zb-secondary);font-size:1.25rem;">@Model.CurrentPlan.PlanName</div>
                <div style="color:var(--zb-text-muted);font-size:.85rem;">@Model.CurrentPlan.MonthlyPrice.ToString("C") / month</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="zb-table-card h-100">
            <div class="p-3">
                <div class="zb-kpi-label">Subscription Status</div>
                <div class="zb-kpi-value" style="color:var(--zb-accent);font-size:1.25rem;">@Model.Business.SubscriptionStatus</div>
                <div style="color:var(--zb-text-muted);font-size:.85rem;">Period end: @(PhilippineTime.ToDateTime(Model.Business.CurrentPeriodEnd)?.ToString("yyyy-MM-dd") ?? "N/A")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="zb-table-card h-100">
            <div class="p-3">
                <div class="zb-kpi-label">Domain</div>
                <div class="zb-kpi-value" style="color:var(--zb-text);font-size:1.25rem;">@Model.Business.DomainPrefix</div>
                <div style="color:var(--zb-text-muted);font-size:.85rem;">Business: @Model.Business.BusinessName</div>
            </div>
        </div>
    </div>
</div>

<div class="zb-table-card mb-4">
    <div class="p-3" style="border-bottom:1px solid rgba(6,182,212,0.15);">
        <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-box-seam me-2"></i>Available Plans</h6>
    </div>
    <div class="p-4">
        <div class="row g-3">
            @foreach (var plan in Model.AvailablePlans)
            {
                var isCurrent = plan.PlanId == Model.CurrentPlan.PlanId;
                <div class="col-md-4">
                    <div style="background:var(--zb-primary);border:1px solid @(isCurrent ? "var(--zb-secondary)" : "var(--zb-primary-alt)");border-radius:0.5rem;" class="p-3 h-100">
                        <h5 style="color:var(--zb-text);">@plan.PlanName</h5>
                        <div class="mb-2" style="color:var(--zb-secondary);font-weight:600;">@plan.MonthlyPrice.ToString("C") / month</div>
                        <div class="small mb-3" style="color:var(--zb-text-muted);">Max tables: @plan.MaxTablesAllowed</div>

                        <form asp-controller="Billing" asp-action="PayAndSetPlan" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="planId" value="@plan.PlanId" />
                            <button type="submit" class="btn btn-sm fw-semibold" style="background:@(isCurrent ? "rgba(6,182,212,0.15)" : "var(--zb-secondary)");color:@(isCurrent ? "var(--zb-secondary)" : "#0f172a");border:@(isCurrent ? "1px solid rgba(6,182,212,0.3)" : "none");">
                                @(isCurrent ? "Renew Current Plan via Stripe" : "Pay & Switch Plan via Stripe")
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="zb-table-card">
    <div class="p-3" style="border-bottom:1px solid rgba(6,182,212,0.15);">
        <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-receipt me-2"></i>Recent Subscription Invoices</h6>
    </div>
    <div class="table-responsive">
        <table class="table zb-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Plan</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Coverage</th>
                    <th>Reference</th>
                </tr>
            </thead>
            <tbody data-paginate="5">
            @if (Model.RecentInvoices.Any())
            {
                @foreach (var invoice in Model.RecentInvoices)
                {
                    <tr>
                        <td>@PhilippineTime.ToDateTime(invoice.IssuedAt).ToString("yyyy-MM-dd")</td>
                        <td>@invoice.Plan.PlanName</td>
                        <td class="zb-mono" style="color:var(--zb-secondary);">@invoice.Amount.ToString("C")</td>
                        <td>@invoice.Status</td>
                        <td>@PhilippineTime.ToDateTime(invoice.PeriodStart).ToString("yyyy-MM-dd") to @PhilippineTime.ToDateTime(invoice.PeriodEnd).ToString("yyyy-MM-dd")</td>
                        <td class="zb-mono">@invoice.ExternalReference</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-3" style="color:var(--zb-text-muted);">No subscription invoices yet.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
