@model IEnumerable<ZoneBill_Lloren.Models.Invoice>
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "Invoices";
    var today = PhilippineTime.Now.Date;
    var totalAmt = Model.Sum(i => i.TotalAmount);
    var paid = Model.Count(i => i.PaymentStatus == "Paid");
    var unpaid = Model.Count(i => i.PaymentStatus != "Paid");
    var overdue = Model.Count(i => i.PaymentStatus != "Paid" && PhilippineTime.ToDateTime(i.GeneratedDate).Date < today.AddDays(-3));
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-receipt-cutoff me-2" style="color:var(--zb-secondary);"></i>Invoices</h4>
        <p class="text-muted small mb-0">Billing records for all completed sessions.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> New Invoice
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Revenue</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@totalAmt.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(34,197,94,0.4);">
            <div class="zb-kpi-label">Paid</div>
            <div class="zb-kpi-value" style="color:#22c55e;">@paid</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(249,115,22,0.4);">
            <div class="zb-kpi-label">Unpaid</div>
            <div class="zb-kpi-value" style="color:var(--zb-accent);">@unpaid</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(239,68,68,0.4);">
            <div class="zb-kpi-label">Overdue (&gt;3 days)</div>
            <div class="zb-kpi-value" style="color:#ef4444;">@overdue</div>
        </div>
    </div>
</div>

<!-- Status filter tabs -->
<div class="d-flex gap-2 mb-3">
    <button type="button" class="inv-filter-btn zb-badge active-filter" data-filter="all"
            style="cursor:pointer;padding:4px 14px;border-radius:20px;border:1px solid rgba(6,182,212,0.35);background:rgba(6,182,212,0.15);color:var(--zb-secondary);">All</button>
    <button type="button" class="inv-filter-btn zb-badge" data-filter="Paid"
            style="cursor:pointer;padding:4px 14px;border-radius:20px;border:1px solid rgba(34,197,94,0.35);background:transparent;color:#94a3b8;">Paid</button>
    <button type="button" class="inv-filter-btn zb-badge" data-filter="Unpaid"
            style="cursor:pointer;padding:4px 14px;border-radius:20px;border:1px solid rgba(249,115,22,0.35);background:transparent;color:#94a3b8;">Unpaid</button>
    <button type="button" class="inv-filter-btn zb-badge" data-filter="overdue"
            style="cursor:pointer;padding:4px 14px;border-radius:20px;border:1px solid rgba(239,68,68,0.35);background:transparent;color:#94a3b8;">Overdue</button>
</div>

<form asp-action="BulkMarkPaid" method="post" id="bulkPaidForm">
    @Html.AntiForgeryToken()
    <div class="zb-table-card">
        <div class="px-4 pt-3 pb-2 border-bottom d-flex align-items-center justify-content-between" style="border-color:rgba(6,182,212,0.15)!important;">
            <div class="d-flex align-items-center gap-2">
                <input type="checkbox" id="selectAll" style="width:15px;height:15px;accent-color:var(--zb-secondary);">
                <label for="selectAll" class="mb-0 small" style="color:var(--zb-text-muted);cursor:pointer;">Select all</label>
            </div>
            <button type="submit" id="bulkPaidBtn" class="btn btn-sm fw-semibold" style="background:rgba(34,197,94,0.15);color:#22c55e;border:1px solid rgba(34,197,94,0.3);display:none;">
                <i class="bi bi-check2-all me-1"></i> Mark Selected as Paid
            </button>
        </div>
        <div class="table-responsive">
            <table class="table zb-table mb-0">
                <thead>
                    <tr>
                        <th style="width:36px;"></th>
                        <th>Business</th>
                        <th>Booking</th>
                        <th>Total</th>
                        <th>Tax</th>
                        <th>Status</th>
                        <th>Generated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody data-paginate="5">
                    @foreach (var item in Model)
                    {
                        var statusClass = item.PaymentStatus == "Paid" ? "zb-badge-green" : "zb-badge-orange";
                        var isPaid = item.PaymentStatus == "Paid";
                        var isOverdue = !isPaid && PhilippineTime.ToDateTime(item.GeneratedDate).Date < today.AddDays(-3);
                        var rowStyle = isOverdue ? "background:rgba(239,68,68,0.06);border-left:3px solid rgba(239,68,68,0.5);" : "";
                        <tr data-status="@item.PaymentStatus" data-overdue="@isOverdue.ToString().ToLower()" style="@rowStyle">
                            <td>
                                @if (!isPaid)
                                {
                                    <input type="checkbox" name="invoiceIds" value="@item.InvoiceId" class="inv-chk"
                                           style="width:15px;height:15px;accent-color:var(--zb-secondary);">
                                }
                            </td>
                            <td class="fw-semibold" style="color:var(--zb-text);">@item.Business?.BusinessName</td>
                            <td>@item.Booking?.BookingStatus</td>
                            <td class="fw-semibold" style="color:var(--zb-secondary);">@item.TotalAmount.ToString("C")</td>
                            <td>@item.TaxRateApplied.ToString("0.##")%</td>
                            <td>
                                <span class="zb-badge @statusClass">@item.PaymentStatus</span>
                                @if (isOverdue) { <span class="zb-badge" style="background:rgba(239,68,68,0.12);color:#ef4444;border:1px solid rgba(239,68,68,0.3);font-size:.65rem;margin-left:4px;">Overdue</span> }
                            </td>
                            <td><span class="zb-mono">@PhilippineTime.ToDateTime(item.GeneratedDate).ToString("MMM d, h:mm tt")</span></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@item.InvoiceId" class="zb-action-btn" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Receipt" asp-route-id="@item.InvoiceId" target="_blank" class="zb-action-btn" title="Print Receipt"><i class="bi bi-printer"></i></a>
                                    @if (!isPaid)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.InvoiceId" class="zb-action-btn" title="Receive Payment" style="color:#22c55e;"><i class="bi bi-cash-coin"></i></a>
                                    }
                                    <a asp-action="Edit" asp-route-id="@item.InvoiceId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.InvoiceId" class="zb-action-btn zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</form>

@section Scripts {
<script>
// Status filter tabs
(function () {
    var allRows = Array.from(document.querySelectorAll('#bulkPaidForm tbody tr'));
    var btns = document.querySelectorAll('.inv-filter-btn');
    btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
            btns.forEach(function (b) {
                b.style.background = 'transparent';
                b.style.color = '#94a3b8';
            });
            btn.style.color = 'var(--zb-secondary)';
            btn.style.background = 'rgba(6,182,212,0.15)';
            var f = btn.getAttribute('data-filter');
            allRows.forEach(function (r) {
                if (f === 'all') r.setAttribute('data-hidden-filter', '');
                else if (f === 'overdue') r.setAttribute('data-hidden-filter', r.getAttribute('data-overdue') === 'true' ? '' : 'y');
                else r.setAttribute('data-hidden-filter', r.getAttribute('data-status') === f ? '' : 'y');
                r.style.display = r.getAttribute('data-hidden-filter') === 'y' ? 'none' : '';
            });
        });
    });

    // Bulk select / mark paid button visibility
    var selectAll = document.getElementById('selectAll');
    var bulkBtn = document.getElementById('bulkPaidBtn');
    function updateBulkBtn() {
        var checked = document.querySelectorAll('.inv-chk:checked').length;
        bulkBtn.style.display = checked > 0 ? '' : 'none';
        bulkBtn.textContent = '';
        bulkBtn.innerHTML = '<i class="bi bi-check2-all me-1"></i> Mark ' + checked + ' as Paid';
    }
    selectAll.addEventListener('change', function () {
        document.querySelectorAll('.inv-chk').forEach(function (c) { c.checked = selectAll.checked; });
        updateBulkBtn();
    });
    document.querySelectorAll('.inv-chk').forEach(function (c) {
        c.addEventListener('change', updateBulkBtn);
    });
})();
</script>
}