@model ZoneBill_Lloren.Models.JournalEntryLine

@{
    ViewData["Title"] = "Edit Journal Entry Line";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-pencil-square me-2" style="color:var(--zb-secondary);"></i>Edit Journal Entry Line</h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="JournalLineId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="JournalEntryId" class="form-label zb-form-label"></label>
                    <select asp-for="JournalEntryId" class="form-select zb-form-input" asp-items="ViewBag.JournalEntryId"></select>
                    <span asp-validation-for="JournalEntryId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountId" class="form-label zb-form-label"></label>
                    <select asp-for="AccountId" class="form-select zb-form-input" asp-items="ViewBag.AccountId"></select>
                    <span asp-validation-for="AccountId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Debit" class="form-label zb-form-label"></label>
                    <input asp-for="Debit" class="form-control zb-form-input" />
                    <span asp-validation-for="Debit" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Credit" class="form-label zb-form-label"></label>
                    <input asp-for="Credit" class="form-control zb-form-input" />
                    <span asp-validation-for="Credit" class="text-danger small"></span>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;"><i class="bi bi-check-lg me-1"></i>Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
