@model IEnumerable<ZoneBill_Lloren.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

@{
    var total = Model.Count();
    var active = Model.Count(b => b.BookingStatus == "Active");
    var completed = Model.Count(b => b.BookingStatus == "Completed");
    var cancelled = Model.Count(b => b.BookingStatus == "Cancelled");
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-calendar-check me-2" style="color:var(--zb-secondary);"></i>Bookings</h4>
        <p class="text-muted small mb-0">All reservation records for your venue.</p>
    </div>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-accent);color:#fff;border:none;">
        <i class="bi bi-plus-lg me-1"></i> New Booking
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card">
            <div class="zb-kpi-label">Total</div>
            <div class="zb-kpi-value">@total</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Active</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@active</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(34,197,94,0.4);">
            <div class="zb-kpi-label">Completed</div>
            <div class="zb-kpi-value" style="color:#22c55e;">@completed</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(239,68,68,0.4);">
            <div class="zb-kpi-label">Cancelled</div>
            <div class="zb-kpi-value" style="color:#ef4444;">@cancelled</div>
        </div>
    </div>
</div>

<div class="zb-table-card">
    <div class="table-responsive">
        <table class="table zb-table mb-0">
            <thead>
                <tr>
                    <th>Space</th>
                    <th>Customer</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Duration</th>
                    <th>Rate/hr</th>
                    <th>Status</th>
                    <th>Reference</th>
                    <th></th>
                </tr>
            </thead>
            <tbody data-paginate="5">
                @foreach (var item in Model)
                {
                    var statusClass = item.BookingStatus == "Active" ? "zb-badge-cyan" :
                                     item.BookingStatus == "Completed" ? "zb-badge-green" : "zb-badge-red";
                    <tr>
                        <td class="fw-semibold" style="color:var(--zb-text);">@item.Space?.SpaceName</td>
                        <td>@item.Customer?.Name</td>
                        <td><span class="zb-mono">@item.StartTime.ToString("MMM d, h:mm tt")</span></td>
                        <td><span class="zb-mono">@(item.EndTime.HasValue ? item.EndTime.Value.ToString("MMM d, h:mm tt") : "—")</span></td>
                        <td>@(item.DurationHours.HasValue ? $"{item.DurationHours:0.##} hr" : "—")</td>
                        <td>₱@item.LockedHourlyRate.ToString("0.00")</td>
                        <td><span class="zb-badge @statusClass">@item.BookingStatus</span></td>
                        <td><span class="zb-mono text-muted">@item.ReferenceCode</span></td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@item.BookingId" class="zb-action-btn"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.BookingId" class="zb-action-btn"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.BookingId" class="zb-action-btn zb-action-danger"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
