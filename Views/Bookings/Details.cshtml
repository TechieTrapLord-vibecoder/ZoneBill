@model ZoneBill_Lloren.Models.Booking

@{
    ViewData["Title"] = "Booking Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-info-circle me-2" style="color:var(--zb-secondary);"></i>Booking Details</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.BookingId" class="btn btn-sm fw-semibold" style="background:rgba(249,115,22,0.12);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Business)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Business.BusinessName)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Space)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Space.CurrentStatus)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.Customer)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.Customer.Name)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.StartTime)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.StartTime)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.EndTime)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.EndTime)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.DurationHours)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.DurationHours)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.LockedHourlyRate)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.LockedHourlyRate)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.BookingStatus)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.BookingStatus)</dd>

            <dt class="col-sm-3 zb-form-label py-2">@Html.DisplayNameFor(model => model.ReferenceCode)</dt>
            <dd class="col-sm-9 py-2" style="color:var(--zb-text);">@Html.DisplayFor(model => model.ReferenceCode)</dd>
        </dl>
    </div>
</div>
