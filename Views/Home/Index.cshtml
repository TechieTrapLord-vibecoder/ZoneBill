                            </div>
                            <div class="lp-chart-col">
                                <div class="lp-bar transition-all duration-500 hover:opacity-80" style="height:80%;background:var(--zb-secondary);"></div>
                                <div class="lp-bar-lbl">Tue</div>
                            </div>
                            <div class="lp-chart-col">
