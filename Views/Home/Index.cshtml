@model IEnumerable<ZoneBill_Lloren.Models.SubscriptionPlan>

@{
    ViewData["Title"] = "ZoneBill – Venue &amp; Reservation Platform";
    Layout = "_LandingLayout";
}

@* ═══════════════════════════════════════════════════════════════
   NAVBAR
═══════════════════════════════════════════════════════════════ *@
<nav class="lp-navbar navbar navbar-expand-lg fixed-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <img src="~/images/ZoneBill.png" alt="ZoneBill" class="lp-nav-logo" />
        </a>
        <button class="navbar-toggler lp-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#lpNav">
            <i class="bi bi-list" style="color:#06B6D4;font-size:1.6rem;"></i>
        </button>
        <div class="collapse navbar-collapse" id="lpNav">
            <ul class="navbar-nav mx-auto gap-lg-4">
                <li class="nav-item"><a class="lp-nav-link" href="#features">Features</a></li>
                <li class="nav-item"><a class="lp-nav-link" href="#pricing">Pricing</a></li>
                <li class="nav-item"><a class="lp-nav-link" href="#faq">FAQ</a></li>
            </ul>
            <div class="d-flex gap-2 mt-3 mt-lg-0">
                <a href="/Account/Login" class="btn lp-btn-outline">Login</a>
                <a href="#pricing" class="btn lp-btn-accent">Get Started</a>
            </div>
        </div>
    </div>
</nav>

@* ═══════════════════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════════════════ *@
<section class="lp-hero d-flex align-items-center">
    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center mb-4" role="alert">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success text-center mb-4" role="alert">@TempData["Success"]</div>
        }
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="lp-hero-badge mb-3">
                    <i class="bi bi-lightning-charge-fill me-1" style="color:#F97316;"></i>
                    <span>All-in-One Venue Platform</span>
                </div>
                <h1 class="lp-hero-headline">
                    The Smart Way to Run Your
                    <span class="lp-gradient-text">Entertainment Business</span>
                </h1>
                <p class="lp-hero-sub">
                    ZoneBill unifies front desk POS, smart bookings, customer QR portals,
                    inventory tracking, and double-entry accounting — in one sleek system built for
                    billiard halls, board game cafés, KTVs, escape rooms, and gaming shops.
                </p>
                <div class="d-flex gap-3 flex-wrap mt-4">
                    <a href="#pricing" class="btn lp-btn-accent lp-btn-lg">
                        Get Started <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                    <a href="#features" class="btn lp-btn-outline lp-btn-lg">
                        Explore Features
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="lp-hero-mockup">
                    <div class="lp-stat-card" style="top:8%;left:0;">
                        <div class="lp-stat-icon"><i class="bi bi-calendar2-check"></i></div>
                        <div>
                            <div class="lp-stat-label">Active Bookings</div>
                            <div class="lp-stat-value">24</div>
                        </div>
                    </div>
                    <div class="lp-stat-card lp-stat-accent" style="top:38%;right:0;">
                        <div class="lp-stat-icon lp-stat-icon-accent"><i class="bi bi-cash-coin"></i></div>
                        <div>
                            <div class="lp-stat-label">Revenue Today</div>
                            <div class="lp-stat-value">₱12,840</div>
                        </div>
                    </div>
                    <div class="lp-stat-card" style="bottom:8%;left:12%;">
                        <div class="lp-stat-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div>
                            <div class="lp-stat-label">Open Tables</div>
                            <div class="lp-stat-value">7 / 12</div>
                        </div>
                    </div>
                    <div class="lp-hero-screen">
                        <div class="lp-screen-header">
                            <span class="lp-screen-dot" style="background:#ef4444;"></span>
                            <span class="lp-screen-dot" style="background:#f97316;"></span>
                            <span class="lp-screen-dot" style="background:#22c55e;"></span>
                            <span style="color:#94a3b8;font-size:.7rem;margin-left:.5rem;">ZoneBill — Front Desk</span>
                        </div>
                        <div class="lp-screen-body">
                            <div class="lp-screen-row">
                                <div class="lp-table-chip lp-chip-occupied">Table 1<br><small>2h 14m</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 2<br><small>1h 05m</small></div>
                                <div class="lp-table-chip lp-chip-free">Table 3<br><small>Open</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 4<br><small>0h 48m</small></div>
                            </div>
                            <div class="lp-screen-row mt-2">
                                <div class="lp-table-chip lp-chip-free">Table 5<br><small>Open</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 6<br><small>3h 01m</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 7<br><small>0h 22m</small></div>
                                <div class="lp-table-chip lp-chip-free">Table 8<br><small>Open</small></div>
                            </div>
                            <div class="lp-screen-bar mt-3">
                                <span style="color:#94a3b8;font-size:.7rem;">Today's Revenue</span>
                                <span style="color:#06b6d4;font-weight:700;font-size:.85rem;">₱12,840.00</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   VENUE TYPES MARQUEE
═══════════════════════════════════════════════════════════════ *@
<section class="lp-marquee-section">
    <div class="lp-marquee-track">
        @for (int i = 0; i < 3; i++)
        {
            <span class="lp-marquee-item"><i class="bi bi-controller"></i> Billiard Hall</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-dice-5"></i> Board Game Café</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-music-note-beamed"></i> KTV / Karaoke</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-door-open"></i> Escape Room</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-pc-display"></i> Gaming Shop</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-cup-straw"></i> Café &amp; Bar</span>
            <span class="lp-marquee-sep">·</span>
        }
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURES GRID
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <span class="lp-section-badge">Features</span>
            <h2 class="lp-section-title mt-2">Everything Your Venue Needs</h2>
            <p class="lp-section-sub">Purpose-built tools for entertainment businesses — no bloat, just what matters.</p>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card">
                    <div class="lp-feature-icon"><i class="bi bi-cash-stack"></i></div>
                    <h5>Front Desk POS</h5>
                    <p>Real-time table/room status, session timers, food &amp; drink orders, and cash drawer management — all in one view.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card">
                    <div class="lp-feature-icon"><i class="bi bi-calendar2-check"></i></div>
                    <h5>Smart Bookings</h5>
                    <p>Accept walk-ins and advance bookings with automatic time tracking, overstay alerts, and customer history.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card lp-feature-card-accent">
                    <div class="lp-feature-icon lp-feature-icon-accent"><i class="bi bi-qr-code-scan"></i></div>
                    <h5>QR Customer Portal</h5>
                    <p>Guests scan a QR code at their table to view their bill, running time, and order items — no app needed.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card">
                    <div class="lp-feature-icon"><i class="bi bi-boxes"></i></div>
                    <h5>Inventory Tracking</h5>
                    <p>Monitor stock levels per item, get low-stock email alerts, and see depletion trends to optimize purchases.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card">
                    <div class="lp-feature-icon"><i class="bi bi-journal-text"></i></div>
                    <h5>Accounting Hub</h5>
                    <p>Full double-entry bookkeeping with chart of accounts, journal entries, and automatic posting from invoices.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="lp-feature-card">
                    <div class="lp-feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5>Financial Reports</h5>
                    <p>Revenue breakdown, top spaces, best-selling items, payment method analysis — with CSV and PDF export.</p>
                </div>
            </div>
        </div>
    </div>
</section>

