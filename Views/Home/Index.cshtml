                        <div class="lp-report-row"><span>Total Revenue</span><span style="color:#06b6d4;font-weight:700;" data-count-to="248500" data-count-prefix="₱" data-count-suffix=".00">₱0</span></div>
                        <div class="lp-report-row"><span>Cash Payments</span><span style="color:#22c55e;" data-count-to="180200" data-count-prefix="₱" data-count-suffix=".00">₱0</span></div>
                        <div class="lp-report-row"><span>GCash / Online</span><span style="color:#f97316;" data-count-to="68300" data-count-prefix="₱" data-count-suffix=".00">₱0</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   PRICING — with gradient border on popular card
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section lp-section-alt relative" id="pricing">
    <div class="container">
        <div class="text-center mb-5 lp-reveal">
            <span class="lp-section-badge">Pricing</span>
            <h2 class="lp-section-title mt-2">Simple, Transparent Plans</h2>
            <p class="lp-section-sub">No hidden fees. Cancel anytime. Includes 14-day free trial.</p>
        </div>
        <div class="row justify-content-center g-4">
            @{
                var plans = Model.Where(p => p.PlanName != "Free").ToList();
                var popularIndex = plans.Count > 1 ? 1 : 0;
            }
            @for (int i = 0; i < plans.Count; i++)
            {
                var plan = plans[i];
                var isPopular = i == popularIndex;
                <div class="col-md-5 col-lg-4 lp-reveal-scale lp-delay-@(i + 1)">
                    <div class="lp-pricing-card @(isPopular ? "lp-pricing-popular lp-gradient-border" : "") lp-hover-glow">
                        @if (isPopular)
                        {
                            <div class="lp-pricing-badge lp-shimmer-badge">Most Popular</div>
                        }
                        <h4 class="lp-pricing-name">@plan.PlanName</h4>
                        <div class="lp-pricing-price">
                            <span class="lp-price-currency">₱</span>
                            <span class="lp-price-amount" data-count-to="@((int)plan.MonthlyPrice)">0</span>
                            <span class="lp-price-period">/mo</span>
                        </div>
                        <ul class="lp-pricing-features">
                            <li><i class="bi bi-check2"></i> Up to <strong>@plan.MaxTablesAllowed spaces/tables</strong></li>
                            <li><i class="bi bi-check2"></i> Full POS &amp; Front Desk</li>
                            <li><i class="bi bi-check2"></i> Smart Bookings &amp; Timers</li>
                            <li><i class="bi bi-check2"></i> QR Customer Portal</li>
                            <li><i class="bi bi-check2"></i> Inventory Tracking</li>
                            <li><i class="bi bi-check2"></i> Financial Reports + Export</li>
                            @if (isPopular)
                            {
                                <li><i class="bi bi-check2"></i> Double-Entry Accounting</li>
                                <li><i class="bi bi-check2"></i> Priority Email Support</li>
                            }
                            else
                            {
                                <li><i class="bi bi-check2"></i> Email Support</li>
                            }
                        </ul>
                        <a href="/Account/RegisterBusiness?planId=@plan.PlanId"
                           class="btn w-100 @(isPopular ? "lp-btn-accent hover:shadow-lg hover:shadow-orange-500/25" : "lp-btn-outline hover:shadow-lg hover:shadow-cyan-500/15") lp-btn-lg mt-3 transition-all duration-300">
                            Get Started
                        </a>
