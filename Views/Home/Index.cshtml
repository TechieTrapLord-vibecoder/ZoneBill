@* ═══════════════════════════════════════════════════════════════
   PRICING
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section lp-section-alt" id="pricing">
    <div class="container">
        <div class="text-center mb-5">
            <span class="lp-section-badge">Pricing</span>
            <h2 class="lp-section-title mt-2">Simple, Transparent Plans</h2>
            <p class="lp-section-sub">No hidden fees. Cancel anytime. Includes 14-day free trial.</p>
        </div>
        <div class="row justify-content-center g-4">
            @{
                var plans = Model.Where(p => p.PlanName != "Free").ToList();
                var popularIndex = plans.Count > 1 ? 1 : 0;
            }
            @for (int i = 0; i < plans.Count; i++)
            {
                var plan = plans[i];
                var isPopular = i == popularIndex;
                <div class="col-md-5 col-lg-4">
                    <div class="lp-pricing-card @(isPopular ? "lp-pricing-popular" : "")">
                        @if (isPopular)
                        {
                            <div class="lp-pricing-badge">Most Popular</div>
                        }
                        <h4 class="lp-pricing-name">@plan.PlanName</h4>
                        <div class="lp-pricing-price">
                            <span class="lp-price-currency">₱</span>
                            <span class="lp-price-amount">@plan.MonthlyPrice.ToString("0")</span>
                            <span class="lp-price-period">/mo</span>
                        </div>
                        <ul class="lp-pricing-features">
                            <li><i class="bi bi-check2"></i> Up to <strong>@plan.MaxTablesAllowed spaces/tables</strong></li>
                            <li><i class="bi bi-check2"></i> Full POS &amp; Front Desk</li>
                            <li><i class="bi bi-check2"></i> Smart Bookings &amp; Timers</li>
                            <li><i class="bi bi-check2"></i> QR Customer Portal</li>
                            <li><i class="bi bi-check2"></i> Inventory Tracking</li>
                            <li><i class="bi bi-check2"></i> Financial Reports + Export</li>
                            @if (isPopular)
                            {
                                <li><i class="bi bi-check2"></i> Double-Entry Accounting</li>
                                <li><i class="bi bi-check2"></i> Priority Email Support</li>
                            }
                            else
                            {
                                <li><i class="bi bi-check2"></i> Email Support</li>
                            }
                        </ul>
                        <a href="/Account/RegisterBusiness?planId=@plan.PlanId"
                           class="btn w-100 @(isPopular ? "lp-btn-accent" : "lp-btn-outline") lp-btn-lg mt-3">
                            Get Started
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FAQ
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section" id="faq">
    <div class="container">
        <div class="text-center mb-5">
            <span class="lp-section-badge">FAQ</span>
            <h2 class="lp-section-title mt-2">Frequently Asked Questions</h2>
            <p class="lp-section-sub">Got questions? We have answers.</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion lp-accordion" id="faqAccordion">
                    <div class="accordion-item lp-faq-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button lp-faq-btn" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                What type of businesses can use ZoneBill?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body lp-faq-body">
                                ZoneBill is built for time-based entertainment venues — billiard halls, board game cafés, KTV bars, escape rooms, gaming shops, and hybrid café-entertainment setups. If you bill by the hour and manage tables or rooms, ZoneBill fits.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item lp-faq-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button lp-faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                How does the QR customer portal work?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body lp-faq-body">
                                Each table or room gets a unique QR code. Your customers scan it to view their running bill, elapsed time, and any food/drink orders placed — completely in real time. No app download required.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item lp-faq-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button lp-faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Do I need accounting knowledge to use the accounting features?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body lp-faq-body">
                                No. ZoneBill auto-posts journal entries for every POS invoice, so the books stay accurate by default. You can review chart of accounts and export reports for your accountant — no manual entry needed.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item lp-faq-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button lp-faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Can I manage multiple staff roles?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body lp-faq-body">
                                Yes. ZoneBill supports four staff roles: Main Admin, Manager, Cashier, and Staff. Each role has tailored access — cashiers see the POS, managers see reports, and admins control everything including billing and user management.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item lp-faq-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button lp-faq-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                Is there a free trial?
                            </button>
                        </h2>
                        <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body lp-faq-body">
                                Yes — every new business gets a 14-day free trial on any plan. No credit card required to start. You can upgrade, downgrade, or cancel at any time from your billing dashboard.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   CTA BANNER
═══════════════════════════════════════════════════════════════ *@
<section class="lp-cta-section">
    <div class="container text-center">
        <h2 class="lp-cta-title">Ready to Modernize Your Venue?</h2>
        <p class="lp-cta-sub">Join hundreds of entertainment businesses already using ZoneBill.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap mt-4">
            <a href="#pricing" class="btn lp-btn-accent lp-btn-lg">Start Free Trial</a>
            <a href="/Account/Login" class="btn lp-btn-outline lp-btn-lg">Login to Dashboard</a>
        </div>
