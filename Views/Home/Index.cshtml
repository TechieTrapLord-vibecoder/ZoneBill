@model IEnumerable<ZoneBill_Lloren.Models.SubscriptionPlan>

@{
    ViewData["Title"] = "ZoneBill – Venue & Reservation Platform";
    Layout = "_LandingLayout";
}

@* ═══════════════════════════════════════════════════════════════
   NAVBAR
═══════════════════════════════════════════════════════════════ *@
<nav class="lp-navbar navbar navbar-expand-lg fixed-top transition-all duration-300">
    <div class="container">
        <a class="navbar-brand" href="/">
            <img src="~/images/ZoneBill.png" alt="ZoneBill" class="lp-nav-logo" />
        </a>
        <button class="navbar-toggler lp-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#lpNav">
            <i class="bi bi-list" style="color:#06B6D4;font-size:1.6rem;"></i>
        </button>
        <div class="collapse navbar-collapse" id="lpNav">
            <ul class="navbar-nav mx-auto gap-lg-4">
                <li class="nav-item"><a class="lp-nav-link transition-colors duration-200" href="#features">Features</a></li>
                <li class="nav-item"><a class="lp-nav-link transition-colors duration-200" href="#pricing">Pricing</a></li>
                <li class="nav-item"><a class="lp-nav-link transition-colors duration-200" href="#faq">FAQ</a></li>
            </ul>
            <div class="d-flex gap-2 mt-3 mt-lg-0">
                <a href="/Account/Login" class="btn lp-btn-outline hover:shadow-lg hover:shadow-cyan-500/10 transition-all duration-200">Login</a>
                <a href="#pricing" class="btn lp-btn-accent hover:shadow-lg hover:shadow-orange-500/20 transition-all duration-200">Get Started</a>
            </div>
        </div>
    </div>
</nav>

@* ═══════════════════════════════════════════════════════════════
   HERO — with orbs, noise texture, staggered animations
═══════════════════════════════════════════════════════════════ *@
<section class="lp-hero d-flex align-items-center relative overflow-hidden lp-noise">
    @* Background glow orbs (parallax on mouse move) *@
    <div class="lp-orb lp-orb-cyan animate-float-slow" style="width:500px;height:500px;top:-10%;left:-10%;"></div>
    <div class="lp-orb lp-orb-orange animate-float-medium" style="width:350px;height:350px;bottom:5%;right:-5%;"></div>
    <div class="lp-orb lp-orb-cyan animate-float-fast" style="width:200px;height:200px;top:50%;left:60%;opacity:0.08;"></div>

    @* Dot grid subtle texture *@
    <div class="absolute inset-0 lp-dot-grid opacity-30 pointer-events-none" style="z-index:0;"></div>

    <div class="container" style="position:relative;z-index:2;">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center mb-4" role="alert">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success text-center mb-4" role="alert">@TempData["Success"]</div>
        }
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                @* Badge with pulse ring *@
                <div class="lp-hero-badge mb-3 animate-hero-badge-pulse lp-reveal lp-delay-1">
                    <i class="bi bi-lightning-charge-fill me-1" style="color:#F97316;"></i>
                    <span>All-in-One Venue Platform</span>
                </div>

                @* Headline *@
                <h1 class="lp-hero-headline lp-reveal lp-delay-2">
                    The Smart Way to Run Your
                    <span class="lp-gradient-text">Entertainment Business</span>
                </h1>

                @* Subtext *@
                <p class="lp-hero-sub lp-reveal lp-delay-3">
                    ZoneBill unifies front desk POS, smart bookings, customer QR portals,
                    inventory tracking, and double-entry accounting — in one sleek system built for
                    billiard halls, board game cafés, KTVs, escape rooms, and gaming shops.
                </p>

                @* CTA buttons *@
                <div class="d-flex gap-3 flex-wrap mt-4 lp-reveal lp-delay-4">
                    <a href="#pricing" class="btn lp-btn-accent lp-btn-lg group hover:shadow-lg hover:shadow-orange-500/25 transition-all duration-300">
                        Get Started <i class="bi bi-arrow-right ms-1 inline-block transition-transform duration-300 group-hover:translate-x-1"></i>
                    </a>
                    <a href="#features" class="btn lp-btn-outline lp-btn-lg hover:shadow-lg hover:shadow-cyan-500/15 transition-all duration-300">
                        Explore Features
                    </a>
                </div>

                @* Trust indicators *@
                <div class="d-flex gap-4 mt-4 lp-reveal lp-delay-5">
                    <div class="d-flex align-items-center gap-1">
                        <i class="bi bi-shield-check" style="color:#22c55e;font-size:0.85rem;"></i>
                        <span style="color:#64748b;font-size:0.78rem;">SSL Secured</span>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <i class="bi bi-credit-card" style="color:#06b6d4;font-size:0.85rem;"></i>
                        <span style="color:#64748b;font-size:0.78rem;">14-Day Free Trial</span>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <i class="bi bi-x-circle" style="color:#f97316;font-size:0.85rem;"></i>
                        <span style="color:#64748b;font-size:0.78rem;">No Credit Card</span>
                    </div>
                </div>
            </div>

            @* Hero mockup *@
            <div class="col-lg-6 lp-reveal-right lp-delay-3">
                <div class="lp-hero-mockup">
                    @* Floating stat cards with enhanced glow *@
                    <div class="lp-stat-card lp-glass animate-float-slow lp-hover-glow" style="top:8%;left:0;">
                        <div class="lp-stat-icon"><i class="bi bi-calendar2-check"></i></div>
                        <div>
                            <div class="lp-stat-label">Active Bookings</div>
                            <div class="lp-stat-value" data-count-to="24">0</div>
                        </div>
                    </div>
                    <div class="lp-stat-card lp-stat-accent lp-glass animate-float-medium lp-hover-glow-accent" style="top:38%;right:0;">
                        <div class="lp-stat-icon lp-stat-icon-accent"><i class="bi bi-cash-coin"></i></div>
                        <div>
                            <div class="lp-stat-label">Revenue Today</div>
                            <div class="lp-stat-value" data-count-to="12840" data-count-prefix="₱">₱0</div>
                        </div>
                    </div>
                    <div class="lp-stat-card lp-glass animate-float-fast lp-hover-glow" style="bottom:8%;left:12%;">
                        <div class="lp-stat-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div>
                            <div class="lp-stat-label">Open Tables</div>
                            <div class="lp-stat-value">7 / 12</div>
                        </div>
                    </div>

                    @* Screen mockup with glow border *@
                    <div class="lp-hero-screen animate-glow-pulse">
                        <div class="lp-screen-header">
                            <span class="lp-screen-dot" style="background:#ef4444;"></span>
                            <span class="lp-screen-dot" style="background:#f97316;"></span>
                            <span class="lp-screen-dot" style="background:#22c55e;"></span>
                            <span style="color:#94a3b8;font-size:.7rem;margin-left:.5rem;">ZoneBill — Front Desk</span>
                        </div>
                        <div class="lp-screen-body">
                            <div class="lp-screen-row">
                                <div class="lp-table-chip lp-chip-occupied">Table 1<br><small>2h 14m</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 2<br><small>1h 05m</small></div>
                                <div class="lp-table-chip lp-chip-free">Table 3<br><small>Open</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 4<br><small>0h 48m</small></div>
                            </div>
                            <div class="lp-screen-row mt-2">
                                <div class="lp-table-chip lp-chip-free">Table 5<br><small>Open</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 6<br><small>3h 01m</small></div>
                                <div class="lp-table-chip lp-chip-occupied">Table 7<br><small>0h 22m</small></div>
                                <div class="lp-table-chip lp-chip-free">Table 8<br><small>Open</small></div>
                            </div>
                            <div class="lp-screen-bar mt-3">
                                <span style="color:#94a3b8;font-size:.7rem;">Today's Revenue</span>
                                <span style="color:#06b6d4;font-weight:700;font-size:.85rem;">₱12,840.00</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   VENUE TYPES MARQUEE
═══════════════════════════════════════════════════════════════ *@
<section class="lp-marquee-section">
    <div class="lp-marquee-track">
        @for (int i = 0; i < 3; i++)
        {
            <span class="lp-marquee-item"><i class="bi bi-controller"></i> Billiard Hall</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-dice-5"></i> Board Game Café</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-music-note-beamed"></i> KTV / Karaoke</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-door-open"></i> Escape Room</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-pc-display"></i> Gaming Shop</span>
            <span class="lp-marquee-sep">·</span>
            <span class="lp-marquee-item"><i class="bi bi-cup-straw"></i> Café &amp; Bar</span>
            <span class="lp-marquee-sep">·</span>
        }
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURES GRID — with glow cards & staggered scroll animation
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section relative" id="features">
    <div class="container">
        <div class="text-center mb-5 lp-reveal">
            <span class="lp-section-badge">Features</span>
            <h2 class="lp-section-title mt-2">Everything Your Venue Needs</h2>
            <p class="lp-section-sub">Purpose-built tools for entertainment businesses — no bloat, just what matters.</p>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-1">
                <div class="lp-feature-card lp-glow-card lp-hover-glow">
                    <div class="lp-feature-icon"><i class="bi bi-cash-stack"></i></div>
                    <h5>Front Desk POS</h5>
                    <p>Real-time table/room status, session timers, food &amp; drink orders, and cash drawer management — all in one view.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-2">
                <div class="lp-feature-card lp-glow-card lp-hover-glow">
                    <div class="lp-feature-icon"><i class="bi bi-calendar2-check"></i></div>
                    <h5>Smart Bookings</h5>
                    <p>Accept walk-ins and advance bookings with automatic time tracking, overstay alerts, and customer history.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-3">
                <div class="lp-feature-card lp-feature-card-accent lp-glow-card lp-hover-glow-accent">
                    <div class="lp-feature-icon lp-feature-icon-accent"><i class="bi bi-qr-code-scan"></i></div>
                    <h5>QR Customer Portal</h5>
                    <p>Guests scan a QR code at their table to view their bill, running time, and order items — no app needed.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-4">
                <div class="lp-feature-card lp-glow-card lp-hover-glow">
                    <div class="lp-feature-icon"><i class="bi bi-boxes"></i></div>
                    <h5>Inventory Tracking</h5>
                    <p>Monitor stock levels per item, get low-stock email alerts, and see depletion trends to optimize purchases.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-5">
                <div class="lp-feature-card lp-glow-card lp-hover-glow">
                    <div class="lp-feature-icon"><i class="bi bi-journal-text"></i></div>
                    <h5>Accounting Hub</h5>
                    <p>Full double-entry bookkeeping with chart of accounts, journal entries, and automatic posting from invoices.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 lp-reveal lp-delay-6">
                <div class="lp-feature-card lp-glow-card lp-hover-glow">
                    <div class="lp-feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5>Financial Reports</h5>
                    <p>Revenue breakdown, top spaces, best-selling items, payment method analysis — with CSV and PDF export.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURE ROW A — Front Desk
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section lp-section-alt relative overflow-hidden">
    @* Subtle orb *@
    <div class="lp-orb lp-orb-cyan" style="width:300px;height:300px;top:10%;right:-10%;opacity:0.06;"></div>

    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 lp-reveal-left">
                <span class="lp-section-badge mb-2 d-inline-block">Front Desk</span>
                <h2 class="lp-section-title">Powerful Dashboard,<br>Zero Confusion</h2>
                <p class="lp-section-sub text-start">
                    Your staff sees everything at a glance — occupied tables, timers, active orders,
                    and shift totals. Start, extend, or close a session in seconds.
                </p>
                <ul class="lp-check-list mt-4">
                    <li class="lp-reveal lp-delay-1"><i class="bi bi-check-circle-fill"></i> Real-time table grid with live timers</li>
                    <li class="lp-reveal lp-delay-2"><i class="bi bi-check-circle-fill"></i> One-click order entry per table</li>
                    <li class="lp-reveal lp-delay-3"><i class="bi bi-check-circle-fill"></i> Cash drawer open/close per shift</li>
                    <li class="lp-reveal lp-delay-4"><i class="bi bi-check-circle-fill"></i> 10-second auto-refresh — always live</li>
                </ul>
            </div>
            <div class="col-lg-7 lp-reveal-right lp-delay-2">
                <div class="lp-mockup-card animate-glow-pulse">
                    <div class="lp-mockup-titlebar">
                        <span class="lp-screen-dot" style="background:#ef4444;"></span>
                        <span class="lp-screen-dot" style="background:#f97316;"></span>
                        <span class="lp-screen-dot" style="background:#22c55e;"></span>
                        <span class="lp-mockup-title ms-2">Front Desk Dashboard</span>
                    </div>
                    <div class="lp-mockup-body">
                        <div class="row g-2 mb-3">
                            <div class="col-3"><div class="lp-mockup-stat" style="border-color:#06b6d4;"><div class="lp-ms-num" style="color:#06b6d4;" data-count-to="8">0</div><div class="lp-ms-lbl">Occupied</div></div></div>
                            <div class="col-3"><div class="lp-mockup-stat" style="border-color:#22c55e;"><div class="lp-ms-num" style="color:#22c55e;" data-count-to="4">0</div><div class="lp-ms-lbl">Open</div></div></div>
                            <div class="col-3"><div class="lp-mockup-stat" style="border-color:#f97316;"><div class="lp-ms-num" style="color:#f97316;" data-count-to="8200" data-count-prefix="₱">₱0</div><div class="lp-ms-lbl">Shift Rev.</div></div></div>
                            <div class="col-3"><div class="lp-mockup-stat" style="border-color:#94a3b8;"><div class="lp-ms-num" style="color:#94a3b8;">6h 20m</div><div class="lp-ms-lbl">Shift Time</div></div></div>
                        </div>
                        <div class="lp-mockup-table-grid">
                            <div class="lpc occupied transition-all duration-200 hover:scale-105">T1<br><small>1h 40m</small></div>
                            <div class="lpc occupied transition-all duration-200 hover:scale-105">T2<br><small>0h 55m</small></div>
                            <div class="lpc free transition-all duration-200 hover:scale-105">T3<br><small>Open</small></div>
                            <div class="lpc occupied transition-all duration-200 hover:scale-105">T4<br><small>2h 10m</small></div>
                            <div class="lpc free transition-all duration-200 hover:scale-105">T5<br><small>Open</small></div>
                            <div class="lpc occupied transition-all duration-200 hover:scale-105">T6<br><small>0h 30m</small></div>
                            <div class="lpc occupied transition-all duration-200 hover:scale-105">T7<br><small>3h 02m</small></div>
                            <div class="lpc free transition-all duration-200 hover:scale-105">T8<br><small>Open</small></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   FEATURE ROW B — Accounting
═══════════════════════════════════════════════════════════════ *@
<section class="lp-section relative overflow-hidden">
    <div class="lp-orb lp-orb-orange" style="width:250px;height:250px;bottom:10%;left:-8%;opacity:0.06;"></div>

    <div class="container">
        <div class="row align-items-center g-5 flex-lg-row-reverse">
            <div class="col-lg-5 lp-reveal-right">
                <span class="lp-section-badge mb-2 d-inline-block">Accounting</span>
                <h2 class="lp-section-title">Built-In Double-Entry<br>Accounting</h2>
                <p class="lp-section-sub text-start">
                    Every invoice automatically creates journal entries. Track your chart of accounts,
                    reconcile cash, and export financial reports — without a separate accounting tool.
                </p>
                <ul class="lp-check-list mt-4">
                    <li class="lp-reveal lp-delay-1"><i class="bi bi-check-circle-fill"></i> Chart of accounts &amp; journal entries</li>
                    <li class="lp-reveal lp-delay-2"><i class="bi bi-check-circle-fill"></i> Auto-posting from POS invoices</li>
                    <li class="lp-reveal lp-delay-3"><i class="bi bi-check-circle-fill"></i> Revenue &amp; payment method reports</li>
