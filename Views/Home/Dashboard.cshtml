@model ZoneBill_Lloren.Models.DashboardViewModel

@{
    ViewData["Title"] = "Business Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-speedometer2 me-2" style="color:var(--zb-secondary);"></i>Business Dashboard</h4>
        <p class="text-muted small mb-0">7-day revenue pulse, top spaces, and top menu movers.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Today Revenue</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.TodayRevenue.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Last 7 Days Revenue</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.SevenDayRevenue.ToString("C")</div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="zb-kpi-card" style="border-color:rgba(249,115,22,0.4);">
            <div class="zb-kpi-label">Unpaid Invoices</div>
            <div class="zb-kpi-value" style="color:var(--zb-accent);">@Model.UnpaidInvoices</div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="zb-kpi-card" style="border-color:rgba(239,68,68,0.4);">
            <div class="zb-kpi-label">Low Stock Alerts</div>
            <div class="zb-kpi-value" style="color:#ef4444;">@Model.LowStockCount</div>
        </div>
    </div>
    <div class="col-6 col-lg">
        <div class="zb-kpi-card" style="border-color:rgba(168,85,247,0.4);">
            <div class="zb-kpi-label">Active Shifts</div>
            <div class="zb-kpi-value" style="color:#a855f7;">@Model.ActiveShiftCount</div>
        </div>
    </div>
</div>

@if (Model.LowStockItems.Any())
{
    <div class="d-flex justify-content-between align-items-center mb-4 px-3 py-2 rounded" role="alert" style="background:rgba(249,115,22,0.12);border:1px solid rgba(249,115,22,0.25);">
        <div style="color:#fdba74;">
            <strong><i class="bi bi-exclamation-triangle me-1"></i>Low stock warning:</strong> @string.Join(", ", Model.LowStockItems)
        </div>
        <a asp-controller="Inventory" asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(249,115,22,0.15);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);">Open Inventory</a>
    </div>
}

<div class="row g-4">
    <div class="col-lg-12">
        <div class="zb-table-card">
            <div class="px-4 pt-3 pb-2 border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
                <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-graph-up me-2"></i>Daily Revenue (Last 7 Days)</h6>
            </div>
            <div class="p-4">
                <canvas id="dailyRevenueChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="zb-table-card">
            <div class="px-4 pt-3 pb-2 border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
                <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-bar-chart-line me-2"></i>Top Spaces By Revenue</h6>
            </div>
            <div class="p-4">
                <canvas id="spaceRevenueChart" height="160"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="zb-table-card">
            <div class="px-4 pt-3 pb-2 border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
                <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-pie-chart me-2"></i>Top Menu Items By Quantity</h6>
            </div>
            <div class="p-4">
                <canvas id="menuQtyChart" height="160"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.borderColor = 'rgba(51,65,85,0.5)';

        const dailyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyLabels));
        const dailySeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyRevenueSeries));
        const spaceLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopSpaceLabels));
        const spaceSeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopSpaceRevenueSeries));
        const menuLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopMenuLabels));
        const menuSeries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopMenuQuantitySeries));

        new Chart(document.getElementById('dailyRevenueChart'), {
            type: 'line',
            data: {
                labels: dailyLabels,
                datasets: [{
                    label: 'Revenue',
                    data: dailySeries,
                    borderColor: '#06b6d4',
                    backgroundColor: 'rgba(6,182,212,0.15)',
                    tension: 0.35,
                    fill: true,
                    pointBackgroundColor: '#06b6d4'
                }]
            }
        });

        new Chart(document.getElementById('spaceRevenueChart'), {
            type: 'bar',
            data: {
                labels: spaceLabels,
                datasets: [{
                    label: 'Revenue',
                    data: spaceSeries,
                    backgroundColor: '#06b6d4',
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y'
            }
        });

        new Chart(document.getElementById('menuQtyChart'), {
            type: 'doughnut',
            data: {
                labels: menuLabels,
                datasets: [{
                    data: menuSeries,
                    backgroundColor: ['#06b6d4', '#f97316', '#a855f7', '#22c55e', '#eab308'],
                    borderColor: '#1e293b',
                    borderWidth: 2
                }]
            }
        });
    </script>
}
