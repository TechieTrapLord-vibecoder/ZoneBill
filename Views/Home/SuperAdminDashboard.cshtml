@model ZoneBill_Lloren.Models.SuperAdminDashboardViewModel
@using ZoneBill_Lloren.Helpers

@{
    ViewData["Title"] = "SaaS Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-globe me-2" style="color:var(--zb-secondary);"></i>SaaS Dashboard</h4>
        <p class="text-muted small mb-0">Portfolio health across all onboarded businesses.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Businesses</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.TotalBusinesses</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(34,197,94,0.4);">
            <div class="zb-kpi-label">Active Businesses</div>
            <div class="zb-kpi-value" style="color:#22c55e;">@Model.ActiveBusinesses</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">Total Users</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.TotalUsers</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(6,182,212,0.4);">
            <div class="zb-kpi-label">MRR</div>
            <div class="zb-kpi-value" style="color:var(--zb-secondary);">@Model.MonthlyRecurringRevenue.ToString("C")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(34,197,94,0.4);">
            <div class="zb-kpi-label">Active Subscriptions</div>
            <div class="zb-kpi-value" style="color:#22c55e;">@Model.ActiveSubscriptions</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="zb-kpi-card" style="border-color:rgba(239,68,68,0.4);">
            <div class="zb-kpi-label">Past Due / Expired</div>
            <div class="zb-kpi-value" style="color:#ef4444;">@Model.PastDueSubscriptions</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="zb-table-card h-100">
            <div class="px-4 pt-3 pb-2 border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
                <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-bar-chart me-2"></i>Businesses By Plan</h6>
            </div>
            <div class="p-4">
                <canvas id="planChart" height="170"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="zb-table-card h-100">
            <div class="px-4 pt-3 pb-2 border-bottom" style="border-color:rgba(6,182,212,0.15)!important;">
                <h6 class="fw-bold mb-0" style="color:var(--zb-secondary);"><i class="bi bi-clock-history me-2"></i>Recent Signups</h6>
            </div>
            <div class="table-responsive">
                <table class="table zb-table mb-0">
                    <thead>
                        <tr>
                            <th>Business</th>
                            <th>Plan</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var signup in Model.RecentSignups)
                    {
                        <tr>
                            <td class="fw-semibold" style="color:var(--zb-text);">@signup.BusinessName</td>
                            <td>@signup.PlanName</td>
                            <td><span class="zb-mono">@PhilippineTime.ToDateTime(signup.CreatedAt).ToString("MMM d, yyyy")</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.borderColor = 'rgba(51,65,85,0.5)';

        const planLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlanLabels));
        const planCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlanBusinessCounts));

        new Chart(document.getElementById('planChart'), {
            type: 'bar',
            data: {
                labels: planLabels,
                datasets: [{
                    label: 'Businesses',
                    data: planCounts,
                    backgroundColor: ['#06b6d4', '#22c55e', '#f97316', '#ef4444', '#a855f7'],
                    borderRadius: 4
                }]
            }
        });
    </script>
}
