@{
    ViewData["Title"] = "Change Password";
}

<style>
    .zb-auth-card { background:var(--zb-primary-mid); border:1px solid rgba(6,182,212,0.2); border-radius:.75rem; overflow:hidden; }
    .zb-auth-header { background:rgba(6,182,212,0.08); padding:1.5rem; text-align:center; border-bottom:1px solid rgba(6,182,212,0.15); }
    .zb-auth-header h3 { color:var(--zb-text); margin:0; font-weight:700; }
    .zb-auth-input { background:var(--zb-primary)!important; color:var(--zb-text)!important; border-color:rgba(6,182,212,0.25)!important; }
    .zb-auth-input:focus { border-color:var(--zb-secondary)!important; box-shadow:0 0 0 2px rgba(6,182,212,0.15)!important; }
    .zb-auth-input::placeholder { color:var(--zb-text-muted)!important; opacity:.6; }
    .zb-auth-input:-webkit-autofill,
    .zb-auth-input:-webkit-autofill:hover,
    .zb-auth-input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px #0f172a inset !important;
        -webkit-text-fill-color: #f1f5f9 !important;
        border-color: rgba(6,182,212,0.25) !important;
        caret-color: #f1f5f9;
        transition: background-color 5000s ease-in-out 0s;
    }
    .zb-auth-label { color:var(--zb-text-muted); font-size:.85rem; }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert border-0 text-center" role="alert" style="background:rgba(34,197,94,0.12);color:#86efac;">@TempData["Success"]</div>
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="zb-auth-card">
            <div class="zb-auth-header">
                <h3><i class="bi bi-key me-2" style="color:var(--zb-secondary);"></i>Change Password</h3>
            </div>
            <div class="p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert border-0" style="background:rgba(239,68,68,0.12);color:#fca5a5;">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label for="currentPassword" class="form-label zb-auth-label">Current Password</label>
                        <input type="password" id="currentPassword" name="currentPassword" class="form-control zb-auth-input" required />
                    </div>
                    <div class="form-group mb-3">
                        <label for="newPassword" class="form-label zb-auth-label">New Password</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-control zb-auth-input" placeholder="At least 8 characters" required minlength="8" />
                    </div>
                    <div class="form-group mb-4">
                        <label for="confirmPassword" class="form-label zb-auth-label">Confirm New Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control zb-auth-input" required minlength="8" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;">Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
