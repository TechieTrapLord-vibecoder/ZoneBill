@model ZoneBill_Lloren.Models.RegisterBusinessViewModel

@{
    ViewData["Title"] = "Register Your Business";
    Layout = "_LandingLayout";
}

<style>
    .zb-reg-input {
        background: #0f172a;
        color: #f1f5f9;
        border: 1px solid rgba(6,182,212,0.25);
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        font-size: 0.9rem;
        width: 100%;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }
    .zb-reg-input:focus {
        border-color: #06b6d4;
        box-shadow: 0 0 0 3px rgba(6,182,212,0.12);
    }
    .zb-reg-input::placeholder { color: rgba(148,163,184,0.6); }
    .zb-reg-input:-webkit-autofill,
    .zb-reg-input:-webkit-autofill:hover,
    .zb-reg-input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px #0f172a inset !important;
        -webkit-text-fill-color: #f1f5f9 !important;
        border-color: rgba(6,182,212,0.25) !important;
        caret-color: #f1f5f9;
        transition: background-color 5000s ease-in-out 0s;
    }
    .zb-reg-label {
        display: block;
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.4rem;
    }
    .zb-reg-section {
        color: #06b6d4;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(6,182,212,0.15);
        margin-bottom: 1.1rem;
        margin-top: 1.25rem;
    }
    .zb-reg-section:first-child { margin-top: 0; }
    .zb-field-error { color: #fca5a5; font-size: 0.8rem; margin-top: 0.25rem; display: block; }
</style>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem 1rem;position:relative;overflow:hidden;">
    <div class="lp-orb lp-orb-cyan" style="width:500px;height:500px;top:-15%;left:-10%;opacity:0.10;"></div>
    <div class="lp-orb lp-orb-orange" style="width:350px;height:350px;bottom:-10%;right:-8%;opacity:0.07;"></div>

    <div style="width:100%;max-width:520px;position:relative;z-index:2;">

        <div class="text-center mb-4">
            <a href="/"><img src="~/images/ZoneBill.png" alt="ZoneBill" style="height:48px;width:auto;" /></a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1rem;color:#fca5a5;font-size:0.88rem;text-align:center;">
                <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
            </div>
        }

        <div style="background:rgba(30,41,59,0.7);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(6,182,212,0.2);border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.35),0 0 40px rgba(6,182,212,0.05);">

            <div style="padding:1.75rem 2rem 1.25rem;text-align:center;border-bottom:1px solid rgba(6,182,212,0.12);">
                <h2 style="color:#f1f5f9;font-size:1.4rem;font-weight:800;margin:0;">
                    <i class="bi bi-building me-2" style="color:#06b6d4;"></i>Start Your @ViewBag.PlanName Plan
                </h2>
                <p style="color:#94a3b8;font-size:0.85rem;margin:0.25rem 0 0;">Get running today for ₱@ViewBag.Price / month</p>
            </div>

            <div style="padding:1.75rem 2rem 2rem;">
                <form asp-action="RegisterBusiness" method="post">
                    <div asp-validation-summary="ModelOnly" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:0.6rem 1rem;color:#fca5a5;font-size:0.85rem;margin-bottom:1rem;"></div>
                    <input type="hidden" asp-for="PlanId" />

                    <div class="zb-reg-section"><i class="bi bi-shop me-1"></i>Business Information</div>

                    <div style="margin-bottom:1.1rem;">
                        <label asp-for="BusinessName" class="zb-reg-label">Business Name</label>
                        <input asp-for="BusinessName" class="zb-reg-input" placeholder="e.g. Rack and Roll Billiards" />
                        <span asp-validation-for="BusinessName" class="zb-field-error"></span>
                    </div>

                    <div class="zb-reg-section"><i class="bi bi-person me-1"></i>Owner Profile</div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.1rem;">
                        <div>
                            <label asp-for="FirstName" class="zb-reg-label">First Name</label>
                            <input asp-for="FirstName" class="zb-reg-input" />
                            <span asp-validation-for="FirstName" class="zb-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="zb-reg-label">Last Name</label>
                            <input asp-for="LastName" class="zb-reg-input" />
                            <span asp-validation-for="LastName" class="text-danger zb-field-error"></span>
                        </div>
                    </div>

                    <div style="margin-bottom:1.1rem;">
                        <label asp-for="EmailAddress" class="zb-reg-label">Email Address</label>
                        <input asp-for="EmailAddress" class="zb-reg-input" placeholder="owner@domain.com" />
                        <span asp-validation-for="EmailAddress" class="zb-field-error"></span>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.75rem;">
                        <div>
                            <label asp-for="Password" class="zb-reg-label">Password</label>
                            <input asp-for="Password" class="zb-reg-input" />
                            <span asp-validation-for="Password" class="zb-field-error"></span>
                        </div>
                        <div>
                            <label asp-for="ConfirmPassword" class="zb-reg-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="zb-reg-input" />
                            <span asp-validation-for="ConfirmPassword" class="zb-field-error"></span>
                        </div>
                    </div>

                    <button type="submit"
                            style="display:block;width:100%;padding:0.75rem;background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;border:none;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 15px rgba(249,115,22,0.3);"
                            onmouseover="this.style.boxShadow='0 6px 25px rgba(249,115,22,0.45)';this.style.transform='translateY(-1px)'"
                            onmouseout="this.style.boxShadow='0 4px 15px rgba(249,115,22,0.3)';this.style.transform='translateY(0)'">
                        <i class="bi bi-check-circle me-1"></i> Complete Registration
                    </button>
                </form>
            </div>
        </div>

        <p style="text-align:center;margin-top:1.25rem;">
            <a asp-controller="Home" asp-action="Index" style="color:#06b6d4;font-size:0.85rem;font-weight:500;text-decoration:none;">
                <i class="bi bi-arrow-left me-1"></i>Back to Pricing
            </a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}