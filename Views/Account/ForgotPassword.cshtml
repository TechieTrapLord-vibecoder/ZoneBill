@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .zb-auth-card { background:var(--zb-primary-mid); border:1px solid rgba(6,182,212,0.2); border-radius:.75rem; overflow:hidden; }
    .zb-auth-header { background:rgba(6,182,212,0.08); padding:1.5rem; text-align:center; border-bottom:1px solid rgba(6,182,212,0.15); }
    .zb-auth-header h3 { color:var(--zb-text); margin:0; font-weight:700; }
    .zb-auth-input { background:var(--zb-primary)!important; color:var(--zb-text)!important; border-color:rgba(6,182,212,0.25)!important; }
    .zb-auth-input:focus { border-color:var(--zb-secondary)!important; box-shadow:0 0 0 2px rgba(6,182,212,0.15)!important; }
    .zb-auth-input::placeholder { color:var(--zb-text-muted)!important; opacity:.6; }
    .zb-auth-input:-webkit-autofill,
    .zb-auth-input:-webkit-autofill:hover,
    .zb-auth-input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 1000px #0f172a inset !important;
        -webkit-text-fill-color: #f1f5f9 !important;
        border-color: rgba(6,182,212,0.25) !important;
        caret-color: #f1f5f9;
        transition: background-color 5000s ease-in-out 0s;
    }
    .zb-auth-label { color:var(--zb-text-muted); font-size:.85rem; }
    .zb-auth-card hr { border-color:rgba(6,182,212,0.15); }
</style>

@if (TempData["Error"] != null)
{
    <div class="alert border-0 text-center" role="alert" style="background:rgba(239,68,68,0.12);color:#fca5a5;">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert border-0 text-center" role="alert" style="background:rgba(34,197,94,0.12);color:#86efac;">@TempData["Success"]</div>
}

<div class="row justify-content-center">
    <div class="col-md-5 mt-5">
        <div class="zb-auth-card">
            <div class="zb-auth-header">
                <h3><i class="bi bi-envelope-open me-2" style="color:var(--zb-secondary);"></i>Forgot Password</h3>
            </div>
            <div class="p-4">
                <p class="mb-4" style="color:var(--zb-text-muted);">Enter your registered email address and we'll send you a reset link.</p>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-group mb-3">
                        <label for="email" class="form-label zb-auth-label">Email Address</label>
                        <input type="email" id="email" name="email" class="form-control zb-auth-input" placeholder="you@example.com" required />
                    </div>
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;">Send Reset Link</button>
                    </div>
                </form>

                <hr />

                <p class="text-center small mb-2" style="color:var(--zb-text-muted);">Already know your email? Sign in with Google instead.</p>
                <form asp-action="GoogleLogin" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-outline-danger">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="me-2" style="vertical-align:-3px">
                                <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.8 2.4 30.2 0 24 0 14.7 0 6.7 5.4 2.7 13.3l7.9 6.1C12.5 13 17.8 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 7.1-10.1 7.1-17z"/>
                                <path fill="#FBBC05" d="M10.6 28.6A14.5 14.5 0 0 1 9.5 24c0-1.6.3-3.1.8-4.6l-7.9-6.1A24 24 0 0 0 0 24c0 3.9.9 7.5 2.6 10.8l8-6.2z"/>
                                <path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.5-5.8c-2 1.4-4.6 2.2-7.7 2.2-6.2 0-11.5-4.2-13.4-9.9l-8 6.2C6.6 42.6 14.7 48 24 48z"/>
                            </svg>
                            Sign in with Google
                        </button>
                    </div>
                </form>

                <div class="text-center">
                    <a asp-action="Login" class="small" style="color:var(--zb-secondary);">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
