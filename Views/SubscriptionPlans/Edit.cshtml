@model ZoneBill_Lloren.Models.SubscriptionPlan

@{
    ViewData["Title"] = "Edit Subscription Plan";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);"><i class="bi bi-pencil-square me-2" style="color:var(--zb-secondary);"></i>Edit Subscription Plan</h4>
    <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
</div>

<div class="zb-table-card">
    <div class="p-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="PlanId" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PlanName" class="form-label zb-form-label"></label>
                    <input asp-for="PlanName" class="form-control zb-form-input" />
                    <span asp-validation-for="PlanName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MonthlyPrice" class="form-label zb-form-label"></label>
                    <input asp-for="MonthlyPrice" class="form-control zb-form-input" />
                    <span asp-validation-for="MonthlyPrice" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MaxTablesAllowed" class="form-label zb-form-label"></label>
                    <input asp-for="MaxTablesAllowed" class="form-control zb-form-input" />
                    <span asp-validation-for="MaxTablesAllowed" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input class="form-check-input" asp-for="IsActive" style="background-color:var(--zb-primary-mid);border-color:var(--zb-text-muted);" />
                        <label class="form-check-label zb-form-label" asp-for="IsActive">@Html.DisplayNameFor(model => model.IsActive)</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;"><i class="bi bi-check-lg me-1"></i>Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
