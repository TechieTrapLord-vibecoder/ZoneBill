@model IEnumerable<ZoneBill_Lloren.Models.OrderDetail>

@{
    ViewData["Title"] = "Order Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0" style="color:var(--zb-text);">
        <i class="bi bi-list-check me-2" style="color:var(--zb-secondary);"></i>Order Details
    </h4>
    <a asp-action="Create" class="btn btn-sm fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;">
        <i class="bi bi-plus-lg me-1"></i>Create New
    </a>
</div>

<div class="zb-table-card">
    <div class="table-responsive">
        <table class="table zb-table align-middle mb-0">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Order)</th>
                    <th>@Html.DisplayNameFor(model => model.MenuItem)</th>
                    <th>@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th>@Html.DisplayNameFor(model => model.LockedUnitPrice)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody data-paginate="5">
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Order.OrderId)</td>
                        <td>@Html.DisplayFor(modelItem => item.MenuItem.ItemName)</td>
                        <td class="zb-mono">@Html.DisplayFor(modelItem => item.Quantity)</td>
                        <td class="zb-mono">@Html.DisplayFor(modelItem => item.LockedUnitPrice)</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.OrderDetailId" class="zb-action-btn" title="Edit"><i class="bi bi-pencil-square"></i></a>
                            <a asp-action="Details" asp-route-id="@item.OrderDetailId" class="zb-action-btn" title="Details"><i class="bi bi-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.OrderDetailId" class="zb-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
