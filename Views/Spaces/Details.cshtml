@model ZoneBill_Lloren.Models.Space

@{
    ViewData["Title"] = "Space Details";
    var statusColor = Model?.CurrentStatus switch {
        "Available"   => ("rgba(34,197,94,0.15)",  "#22c55e"),
        "Occupied"    => ("rgba(6,182,212,0.15)",  "#06b6d4"),
        "Unavailable" => ("rgba(239,68,68,0.15)",  "#ef4444"),
        _             => ("rgba(148,163,184,0.15)", "#94a3b8")
    };
    var qrUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Customer/Space/{Model?.SpaceId}";
    var qrSrc = $"https://quickchart.io/qr?text={Uri.EscapeDataString(qrUrl)}&size=180&margin=2";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-grid fs-4" style="color:var(--zb-secondary);"></i>
        <h4 class="fw-bold mb-0" style="color:var(--zb-text);">@Model?.SpaceName</h4>
        <span class="badge rounded-pill ms-1 fw-semibold" style="background:@statusColor.Item1;color:@statusColor.Item2;font-size:0.72rem;">@Model?.CurrentStatus</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.SpaceId" class="btn btn-sm fw-semibold" style="background:rgba(249,115,22,0.15);color:var(--zb-accent);border:1px solid rgba(249,115,22,0.3);">
            <i class="bi bi-pencil-square me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.12);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Info Card -->
    <div class="col-lg-8">
        <div class="zb-table-card h-100">
            <div class="px-4 pt-4 pb-1" style="border-bottom:1px solid rgba(6,182,212,0.12);">
                <p class="mb-3 fw-semibold" style="color:var(--zb-secondary);font-size:0.8rem;letter-spacing:0.05em;text-transform:uppercase;">
                    <i class="bi bi-info-circle me-1"></i>Space Information
                </p>
            </div>
            <div class="p-4">
                <div class="row g-0">
                    <!-- Space Name -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Space Name</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);color:var(--zb-text);">
                        <span class="fw-semibold">@Model?.SpaceName</span>
                    </div>

                    <!-- Business -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Business</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);color:var(--zb-text);">
                        @Model?.Business?.BusinessName
                    </div>

                    <!-- Floor Area -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Floor Area</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);color:var(--zb-text);">
                        @(string.IsNullOrWhiteSpace(Model?.FloorArea) ? "—" : $"{Model.FloorArea} sqm")
                    </div>

                    <!-- Capacity -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Capacity</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);color:var(--zb-text);">
                        @Model?.Capacity person(s)
                    </div>

                    <!-- Hourly Rate -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Hourly Rate</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="fw-bold" style="color:var(--zb-accent);">₱ @Model?.CurrentHourlyRate.ToString("N2")</span>
                        <span class="text-muted small ms-1">/ hour</span>
                    </div>

                    <!-- Status -->
                    <div class="col-sm-4 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Status</span>
                    </div>
                    <div class="col-sm-8 py-3" style="border-bottom:1px solid rgba(148,163,184,0.08);">
                        <span class="badge rounded-pill fw-semibold" style="background:@statusColor.Item1;color:@statusColor.Item2;">@Model?.CurrentStatus</span>
                    </div>

                    <!-- Active -->
                    <div class="col-sm-4 py-3">
                        <span class="zb-form-label d-block" style="font-size:0.78rem;">Active</span>
                    </div>
                    <div class="col-sm-8 py-3">
                        @if (Model?.IsActive == true)
                        {
                            <span class="badge rounded-pill fw-semibold" style="background:rgba(34,197,94,0.15);color:#22c55e;">Yes</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill fw-semibold" style="background:rgba(239,68,68,0.15);color:#ef4444;">No</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- QR Code Card -->
    <div class="col-lg-4">
        <div class="zb-table-card h-100 text-center">
            <div class="px-4 pt-4 pb-1" style="border-bottom:1px solid rgba(6,182,212,0.12);">
                <p class="mb-3 fw-semibold" style="color:var(--zb-secondary);font-size:0.8rem;letter-spacing:0.05em;text-transform:uppercase;">
                    <i class="bi bi-qr-code me-1"></i>Customer QR
                </p>
            </div>
            <div class="p-4 d-flex flex-column align-items-center gap-3">
                <div class="p-2 rounded" style="background:#fff;display:inline-block;">
                    <img src="@qrSrc" alt="QR Code for @Model?.SpaceName" style="width:180px;height:180px;display:block;" />
                </div>
                <p class="text-muted mb-0" style="font-size:0.72rem;word-break:break-all;">@qrUrl</p>
                <div class="d-flex gap-2 flex-wrap justify-content-center">
                    <button type="button" class="btn btn-sm fw-semibold" style="background:var(--zb-secondary);color:#0f172a;border:none;" onclick="printSpaceQR()">
                        <i class="bi bi-printer me-1"></i>Print
                    </button>
                    <a href="@qrSrc" download="QR-@(Model?.SpaceName?.Replace(" ", "-"))" class="btn btn-sm fw-semibold" style="background:rgba(6,182,212,0.15);color:var(--zb-secondary);border:1px solid rgba(6,182,212,0.3);">
                        <i class="bi bi-download me-1"></i>Download
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function printSpaceQR() {
            var src = '@qrSrc';
            var title = '@Html.Raw(Model?.SpaceName?.Replace("'", "\\'"))';
            var url = '@qrUrl';
            var win = window.open('', '_blank');
            win.document.write('<html><head><title>QR \u2014 ' + title + '</title><style>body{text-align:center;font-family:sans-serif;padding:40px;}</style></head><body>');
            win.document.write('<h2>' + title + '</h2>');
            win.document.write('<img src="' + src + '" style="width:300px;height:300px" />');
            win.document.write('<p style="font-size:14px;margin-top:16px;">Scan to view your tab &amp; order</p>');
            win.document.write('<p style="font-size:11px;color:#666;">' + url + '</p>');
            win.document.write('<script>window.onload=function(){window.print();}<\/script>');
            win.document.write('</body></html>');
            win.document.close();
        }
    </script>
}
